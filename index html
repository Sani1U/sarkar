/* প্রতি প্রশ্ন ১ মিনিট */
let i=0,answers=new Array(questions.length).fill(null);
let time=questions.length*60;
let student="";

/* ===== rest code unchanged ===== */
function startExam(){
 student=document.getElementById("name").value;
 if(!student){alert("নাম লেখো");return;}
 loginBox.classList.add("hidden");
 quizBox.classList.remove("hidden");
 load(); startTimer();
}

function load(){
 qno.innerText=`প্রশ্ন ${i+1}/${questions.length}`;
 document.querySelector(".question").innerText=questions[i].q;
 let html="";
 questions[i].o.forEach((x,j)=>{
   let cls=answers[i]===j?"selected":"";
   html+=`<button class="${cls}" onclick="answer(${j})">${x}</button>`;
 });
 document.querySelector(".options").innerHTML=html;
 bar.style.width=((answers.filter(x=>x!==null).length/questions.length)*100)+"%";
 navigator();
}

function answer(a){
 answers[i]=a;
 let next=-1;
 for(let j=i+1;j<questions.length;j++) if(answers[j]===null){next=j;break;}
 if(next===-1) for(let j=0;j<i;j++) if(answers[j]===null){next=j;break;}
 if(next!==-1) i=next;
 load();
}

function navigator(){
 let n="";
 for(let j=0;j<questions.length;j++){
   let cls=answers[j]!==null?"answered":"";
   n+=`<button class="${cls}" onclick="go(${j})">${j+1}</button>`;
 }
 nav.innerHTML=n;
}

function go(x){i=x;load();}

function startTimer(){
 let t=setInterval(()=>{
   let m=Math.floor(time/60);
   let s=time%60;
   timer.innerText=`সময় ${m}:${String(s).padStart(2,"0")}`;
   time--; if(time<0){clearInterval(t);finish();}
 },1000);
}

function finish(){
 let score=0,reviewHTML="";
 answers.forEach((a,idx)=>{
   let ok=a===questions[idx].a;
   if(ok) score++;
   reviewHTML+=`
   <div class="review-item ${ok?"correct":"wrong"}">
   <p><b>প্রশ্ন ${idx+1}:</b> ${questions[idx].q}</p>
   <p>🟢 সঠিক উত্তর: ${questions[idx].o[questions[idx].a]}</p>
   <p>🔵 তোমার উত্তর: ${a!==null?questions[idx].o[a]:"উত্তর দাওনি"}</p>
   </div>`;
 });
 quizBox.classList.add("hidden");
 resultBox.classList.remove("hidden");
 studentEl.innerText="পরীক্ষার্থী: "+student;
 correct.innerText="✅ সঠিক: "+score;
 wrong.innerText="❌ ভুল: "+(questions.length-score);
 scoreEl.innerText=`মোট স্কোর: ${score}/${questions.length}`;
 accuracy.innerText=`Accuracy: ${((score/questions.length)*100).toFixed(2)}%`;
 reviewBox.classList.remove("hidden");
 reviewList.innerHTML=reviewHTML;
}

function restart(){location.reload();}

const loginBox=document.getElementById("loginBox");
const quizBox=document.getElementById("quizBox");
const resultBox=document.getElementById("resultBox");
const qno=document.getElementById("qno");
const timer=document.getElementById("timer");
const bar=document.getElementById("bar");
const nav=document.getElementById("nav");
const studentEl=document.getElementById("student");
const correct=document.getElementById("correct");
const wrong=document.getElementById("wrong");
const scoreEl=document.getElementById("score");
const accuracy=document.getElementById("accuracy");
const reviewBox=document.getElementById("reviewBox");
const reviewList=document.getElementById("reviewList");
</script>

